---
const today = new Date();
---

<footer class="site-footer" id="contact">
	<div>
		<h2>Let’s build the next platform</h2>
		<p>Open to collaboration on Salesforce, AI automation, and FinTech systems.</p>
	</div>
	<div class="footer-links">
		<button class="btn contact-trigger" type="button" data-open-contact>Open contact form</button>
		<div class="footer-meta">
			<span>Nagpur, Maharashtra, India</span>
		</div>
		<div class="footer-social">
			<a href="https://linkedin.com/in/eduanmoldeep" target="_blank" rel="noreferrer">LinkedIn</a>
			<a href="https://www.salesforce.com/trailblazer/anmoldeeparora" target="_blank" rel="noreferrer">Salesforce Trailblazer</a>
		</div>
		<span class="footer-copy">© {today.getFullYear()} Anmoldeep Singh Arora. All rights reserved.</span>
	</div>
</footer>

<dialog class="contact-modal" id="contact-modal" aria-labelledby="contact-title">
	<form
		class="contact-form"
		method="post"
		action={import.meta.env.PUBLIC_FORMSUBMIT_ENDPOINT}
	>
		<div class="contact-header">
			<h3 id="contact-title">Start a project</h3>
			<button class="contact-close" type="button" data-close-contact>Close</button>
		</div>
		<div class="contact-grid">
			<label>
				Name
				<input name="name" type="text" placeholder="Your full name" required />
			</label>
			<label>
				Work email
				<input name="email" type="email" placeholder="name@company.com" required />
			</label>
			<label>
				Phone
				<input name="phone" type="tel" placeholder="+91 98765 43210" />
			</label>
			<label>
				Company
				<input name="company" type="text" placeholder="Company name" />
			</label>
		</div>
		<label>
			Message
			<textarea name="message" rows="5" placeholder="Tell me about your project or role." required></textarea>
		</label>
		<!-- Honeypot: hidden field to catch bots — real users leave this blank -->
		<input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
		<button class="btn" type="submit">Send message</button>
	</form>
</dialog>

<script>
	const dialog = document.getElementById('contact-modal');
	const openButtons = document.querySelectorAll('[data-open-contact]');
	const closeButtons = document.querySelectorAll('[data-close-contact]');

	if (dialog instanceof HTMLDialogElement) {
		openButtons.forEach((button) =>
			button.addEventListener('click', () => dialog.showModal()),
		);
		closeButtons.forEach((button) =>
			button.addEventListener('click', () => dialog.close()),
		);
		dialog.addEventListener('click', (event) => {
			if (event.target === dialog) {
				dialog.close();
			}
		});
	}
</script>
