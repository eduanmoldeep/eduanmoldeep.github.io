---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const title = `About — ${SITE_TITLE}`;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="bg-noise" aria-hidden="true"></div>
		<Header />
		<main class="page">
			<section class="section">
				<div class="section-header">
					<h1>About</h1>
					<p>
						I’m Anmoldeep Singh Arora, a Lead Software Engineer focused on Salesforce architecture,
						FinTech systems, and AI-powered automation. I’ve delivered secure lending journeys,
						workflow-driven integrations, and Agentforce solutions that reduce manual effort and
						improve customer response times.
					</p>
				</div>
				<div class="summary-grid">
					<div class="summary-card">
						<h3>What I love building</h3>
						<p>
							Reusable architectures, clean system design, and integrations that feel effortless
							for end users.
						</p>
					</div>
					<div class="summary-card">
						<h3>Where I’m heading</h3>
						<p>
							Expanding Agentforce automation and knowledge-grounded AI agents for enterprise teams.
						</p>
					</div>
					<div class="summary-card">
						<h3>Beyond work</h3>
						<p>
							System design learning, mentoring teammates, and experimenting with new platform tools.
						</p>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
